# ── Nginx Proxy Manager Ports ───────────────────────────────────────────────
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=81

# ── Portainer Port ──────────────────────────────────────────────────────────
PORTAINER_PORT=9443

# ── Cloudflare Tunnel Token ─────────────────────────────────────────────────
# Get this from: https://one.dash.cloudflare.com → Networks → Tunnels → Create
# Leave empty to be prompted during setup, or skip Cloudflared entirely
CLOUDFLARED_TOKEN=

# ── Docker Network Name ─────────────────────────────────────────────────────
DOCKER_NETWORK=proxy

# ── Data Directory ──────────────────────────────────────────────────────────
# Host path for persistent volumes (Portainer data, NPM config, SSL certs)
DATA_DIR=/opt/server-data